    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "seed": "node server/db/seed.js"
  },
  "dependencies": {
    "sql.js": "^1.10.3",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "jsonwebtoken": "^9.0.2",
    "node-fetch": "^2.7.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
